{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git force-push *)",
      "Bash(git reset --hard *)"
    ]
  },
  "defaultMode": "acceptEdits",

  "attribution": {
    "commit": "🤖 Generated with Claude Code orchestration",
    "pr": ""
  }
}